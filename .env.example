# =============================================================================
# Pistar — environment template (BLUEPRINT §12)
# Copy to apps/web/.env.local and fill in. NEVER commit real secrets.
# =============================================================================

# --- Database -----------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pistar?schema=public"

# --- Auth.js / NextAuth -------------------------------------------------------
# Generate via:  openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) — for magic-link auth + transactional mail ----------------
RESEND_API_KEY=
RESEND_FROM="Pistar <login@pistar.example>"

# --- Polar (payments inbound) — Merchant of Record -----------------------------
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ENV="sandbox"            # sandbox | production
POLAR_PRODUCT_SINGLE_RUN=      # product UUID
POLAR_PRODUCT_SESSION_PACK=    # product UUID

# --- Wise (payouts outbound) ---------------------------------------------------
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_ENV="sandbox"             # sandbox | production
WISE_WEBHOOK_PUBLIC_KEY=       # for signature verification

# --- Mux (video upload + playback) ---------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Signing key for signed playback URLs (BLUEPRINT §9.2)
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# --- Object storage (Cloudflare R2 or AWS S3) — diplomas, profile pics --------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- Observability ------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en,de,fr"
